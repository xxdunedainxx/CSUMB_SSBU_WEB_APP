---
import TestLayout from '../../layouts/TestLayout.astro';
import { testMap } from '../../react/ts/data/tests';
import TestResultListenerComponent from '../../react/components/TestResultListenerComponent';
import Setup from '../../react/ts/util/Setup'

// Tell Astro which pages to generate at build time
export function getStaticPaths() {
    return Object.keys(testMap).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Get test info
const testInfo = testMap[slug];

if (!testInfo) {
    return Astro.redirect('/404');
}

const setup = new Setup();
const baseUrl = testInfo.file;

const finalTestUrl =
  !setup.config.isProd && testInfo.debugArgs
    ? `${testInfo.file}&${testInfo.debugArgs}`
    : baseUrl;


---

<TestLayout 
    title={testInfo.name}
    description={testInfo.description}
    testName={testInfo.name}
>
    <TestResultListenerComponent
        client:load
        testCategory={testInfo.id}
        iframeSrc={finalTestUrl}
        testName={testInfo.name}
    />
    <script slot="scripts">
        // Optional: Listen for messages from iframe (for test completion, scores, etc.)
        window.addEventListener('message', (event) => {
            console.log('Message from test:', event.data);
        });
    </script>
</TestLayout>
